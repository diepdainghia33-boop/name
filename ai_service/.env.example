# Groq (required for chat)
GROQ_API_KEY=your_groq_api_key

# Optional
ANTHROPIC_API_KEY=

# Render sets PORT automatically (do not hardcode 8001 in production)
PORT=8001

# Skip heavy HuggingFace models on Render free tier
DISABLE_TRANSFORMERS=1

# Optional: TiDB / MySQL (read settings from Laravel DB)
# DB_HOST=
# DB_PORT=4000
# DB_DATABASE=test
# DB_USERNAME=
# DB_PASSWORD=

# Optional: Redis (Upstash)
# REDIS_URL=rediss://default:token@host.upstash.io:6379
